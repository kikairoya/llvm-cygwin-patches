From 6c1fcfe2e75e7f2f158d2d58dd62b1cd7cd77ed8 Mon Sep 17 00:00:00 2001
From: kikairoya <kikairoya@gmail.com>
Date: Tue, 14 Apr 2026 21:09:52 +0900
Subject: [PATCH 36/38] adjust ssaf-plugin test

---
 .../lib/ScalableStaticAnalysisFramework/Plugins/CMakeLists.txt  | 2 +-
 .../Analysis/Scalable/ssaf-format/WPASuite/with-plugin.test     | 2 ++
 clang/test/CMakeLists.txt                                       | 2 +-
 3 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/clang/lib/ScalableStaticAnalysisFramework/Plugins/CMakeLists.txt b/clang/lib/ScalableStaticAnalysisFramework/Plugins/CMakeLists.txt
index b77ffc49c0f9f8a4863392499b32161f78e7eaa2..f3d41914b767698f309693561150fec7a28b9b0b 100644
--- a/clang/lib/ScalableStaticAnalysisFramework/Plugins/CMakeLists.txt
+++ b/clang/lib/ScalableStaticAnalysisFramework/Plugins/CMakeLists.txt
@@ -1,4 +1,4 @@
-if(CLANG_PLUGIN_SUPPORT AND LLVM_ENABLE_PLUGINS AND NOT WIN32)
+if(CLANG_PLUGIN_SUPPORT AND LLVM_ENABLE_PLUGINS AND NOT (WIN32 OR CYGWIN))
   # Plugins must never bring LLVM or Clang libraries in statically.
   # clang-ssaf-analyzer already loads clangScalableStaticAnalysisFrameworkCore
   # and LLVM into the process; a second static copy would produce duplicate
diff --git a/clang/test/Analysis/Scalable/ssaf-format/WPASuite/with-plugin.test b/clang/test/Analysis/Scalable/ssaf-format/WPASuite/with-plugin.test
index b0a419842e80d298048fa20f6b01497d8ae5d440..40a8b0a19913093cf7efdf2a34153ff9e972b3be 100644
--- a/clang/test/Analysis/Scalable/ssaf-format/WPASuite/with-plugin.test
+++ b/clang/test/Analysis/Scalable/ssaf-format/WPASuite/with-plugin.test
@@ -1,6 +1,8 @@
 // Tests for clang-ssaf-format --type wpa that require the example plugin.
 
 // REQUIRES: plugins
+// UNSUPPORTED: system-windows
+// UNSUPPORTED: system-cygwin
 
 // RUN: rm -rf %t
 // RUN: mkdir -p %t
diff --git a/clang/test/CMakeLists.txt b/clang/test/CMakeLists.txt
index cb1f34d2e49bc671b11c79f89c18d8041efb98e1..dca0573b827f2b58f3b72e5d7de02e2d9d4877c4 100644
--- a/clang/test/CMakeLists.txt
+++ b/clang/test/CMakeLists.txt
@@ -207,7 +207,7 @@ if(CLANG_ENABLE_STATIC_ANALYZER)
   endif()
 endif()
 
-if(CLANG_PLUGIN_SUPPORT AND LLVM_ENABLE_PLUGINS AND NOT WIN32)
+if(CLANG_PLUGIN_SUPPORT AND LLVM_ENABLE_PLUGINS AND NOT (WIN32 OR CYGWIN))
   list(APPEND CLANG_TEST_DEPS
     SSAFExamplePlugin
     )
-- 
