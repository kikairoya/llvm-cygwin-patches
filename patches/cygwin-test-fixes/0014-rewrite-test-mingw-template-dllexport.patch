+USE(*ptrOuter<ImportDeclaration>);
+USE(move(*ptrOuter<ImportDeclaration>));
+// CHECK: declare dllimport {{(x86_thiscallcc )?}}void @_ZN5ClassI17ImportDeclarationEC1ERKS1_
