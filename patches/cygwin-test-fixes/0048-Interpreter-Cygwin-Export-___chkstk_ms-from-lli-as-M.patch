From: kikairoya <kikairoya@gmail.com>
Date: Sun, 18 May 2025 22:37:15 +0900
Subject: [PATCH 48/64] [Interpreter][Cygwin] Export ___chkstk_ms from lli as
 MinGW does

---
 llvm/tools/lli/lli.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/llvm/tools/lli/lli.cpp b/llvm/tools/lli/lli.cpp
index 38496cbd5ff77b193edb19055da61515b739680f..53b6ba8e293dca826826cc392e746d51b6ee55dc 100644
--- a/llvm/tools/lli/lli.cpp
+++ b/llvm/tools/lli/lli.cpp
@@ -1289,7 +1289,7 @@ static Expected<std::unique_ptr<orc::ExecutorProcessControl>> launchRemote() {
 //
 // TODO: Move this into libORC at some point, see
 // https://github.com/llvm/llvm-project/issues/56603.
-#ifdef __MINGW32__
+#if defined(__MINGW32__) || defined(__CYGWIN__)
 // This is a MinGW version of #pragma comment(linker, "...") that doesn't
 // require compiling with -fms-extensions.
 #if defined(__i386__)
