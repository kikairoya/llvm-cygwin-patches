Date: Sun, 4 Jan 2026 21:53:48 +0900
Subject: [PATCH 45/54] [Clang][Cygwin] Set default DWARF version to 4

---
 clang/lib/Driver/ToolChains/Cygwin.h | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/clang/lib/Driver/ToolChains/Cygwin.h b/clang/lib/Driver/ToolChains/Cygwin.h
index 9a1b096f8127d4d26c6ebcdbea12abed73bb21ce..22e0284f1599dcbd019e4d83e9fa2c7a239093bb 100644
--- a/clang/lib/Driver/ToolChains/Cygwin.h
+++ b/clang/lib/Driver/ToolChains/Cygwin.h
@@ -34,6 +34,8 @@ public:
                         BoundArch BA,
                         Action::OffloadKind DeviceOffloadKind) const override;
 
+  unsigned GetDefaultDwarfVersion() const override { return 4; }
+
 protected:
   Tool *buildLinker() const override;
 };
