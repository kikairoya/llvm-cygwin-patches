From 26317bc64b06ba23b54817a7304c5c5026438cd7 Mon Sep 17 00:00:00 2001
From: kikairoya <kikairoya@gmail.com>
Date: Sun, 28 Jun 2026 18:16:32 +0900
Subject: [PATCH 47/54] [Clang][Cygwin] Link default-manifest unless
 -nostartfiles nor -shared

---
 clang/lib/Driver/ToolChains/Cygwin.cpp | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/clang/lib/Driver/ToolChains/Cygwin.cpp b/clang/lib/Driver/ToolChains/Cygwin.cpp
index ecf184e340e7c077c8a233d3b89ea71f43b889a1..2faaa3f36d65a898628918fb8ade14e41be507ff 100644
--- a/clang/lib/Driver/ToolChains/Cygwin.cpp
+++ b/clang/lib/Driver/ToolChains/Cygwin.cpp
@@ -401,6 +401,12 @@ void cygwin::Linker::ConstructJob(Compilation &C, const JobAction &JA,
           CmdArgs.push_back(Args.MakeArgString(P));
         }
       }
+      if (!Args.hasArg(options::OPT_mdll, options::OPT_shared)) {
+        static constexpr const char *defmanifest = "default-manifest.o";
+        if (std::string O = ToolChain.GetFilePath(defmanifest);
+            O != defmanifest)
+          CmdArgs.push_back(Args.MakeArgString(std::move(O)));
+      }
       CmdArgs.push_back(Args.MakeArgString(ToolChain.GetFilePath("crtend.o")));
     }
   }
-- 
