diff --git a/clang/test/SemaCXX/attr-exclude_from_explicit_instantiation.ignore-dllattr.cpp b/clang/test/SemaCXX/attr-exclude_from_explicit_instantiation.ignore-dllattr.cpp
index f2a53ab9cf3027aff1d40e8036e0fab03a54b354..5d2e9bbddc2cf4fbaa276c6d557b7a5b5d10662a 100644
--- a/clang/test/SemaCXX/attr-exclude_from_explicit_instantiation.ignore-dllattr.cpp
+++ b/clang/test/SemaCXX/attr-exclude_from_explicit_instantiation.ignore-dllattr.cpp
@@ -1,6 +1,6 @@
-// RUN: %clang_cc1 -triple x86_64-win32 -fms-extensions -fsyntax-only -verify %s
-// RUN: %clang_cc1 -triple x86_64-mingw                 -fsyntax-only -verify %s
-// RUN: %clang_cc1 -triple x86_64-cygwin                -fsyntax-only -verify %s
+// RUN: %clang_cc1 -triple x86_64-win32 -fms-extensions -fsyntax-only -verify=expected %s
+// RUN: %clang_cc1 -triple x86_64-mingw                 -fsyntax-only -verify=expected,mingw %s
+// RUN: %clang_cc1 -triple x86_64-cygwin                -fsyntax-only -verify=expected,mingw %s
 
 // Test that memberwise dllexport and dllimport are warned if the
 // exclude_from_explicit_instantiation attribute is attached.
@@ -65,11 +65,11 @@ struct E {
     __declspec(dllimport) void fn_imported();
   };
 
-  struct __declspec(dllexport) nested_exported_1 { // expected-note{{attribute is here}}
-    EXCLUDE_ATTR void fn_excluded(); // expected-warning{{'exclude_from_explicit_instantiation' attribute takes precedence over 'dllexport' attribute on the enclosing class}}
+  struct __declspec(dllexport) nested_exported_1 { // #dllattr_1
+    EXCLUDE_ATTR void fn_excluded(); // #excludeattr_1
   };
-  struct __declspec(dllimport) nested_imported_1 { // expected-note{{attribute is here}}
-    EXCLUDE_ATTR void fn_excluded(); // expected-warning{{'exclude_from_explicit_instantiation' attribute takes precedence over 'dllimport' attribute on the enclosing class}}
+  struct __declspec(dllimport) nested_imported_1 { // #dllattr_2
+    EXCLUDE_ATTR void fn_excluded(); // #excludeattr_2
   };
 
   // Make sure that any warning isn't emitted if the nested type has no excluded members.
@@ -80,7 +80,21 @@ struct E {
     void fn();
   };
 };
+
+// For MinGW, an explicit instantiation declaration instantiates nested class
+// in the same way as non-Windows platforms or as expected by the Standard.
 extern template struct __declspec(dllimport) E<long>;
+// mingw-note@-1{{in instantiation of member class 'E<long>::nested_exported_1' requested here}}
+// mingw-note@-2{{in instantiation of member class 'E<long>::nested_imported_1' requested here}}
+// mingw-warning@#excludeattr_1 {{'exclude_from_explicit_instantiation' attribute takes precedence over 'dllexport' attribute on the enclosing class}}
+// mingw-note@#dllattr_1 {{attribute is here}}
+// mingw-warning@#excludeattr_2 {{'exclude_from_explicit_instantiation' attribute takes precedence over 'dllimport' attribute on the enclosing class}}
+// mingw-note@#dllattr_2 {{attribute is here}}
+
 template struct __declspec(dllexport) E<int>;
 // expected-note@-1{{in instantiation of member class 'E<int>::nested_exported_1' requested here}}
 // expected-note@-2{{in instantiation of member class 'E<int>::nested_imported_1' requested here}}
+// expected-warning@#excludeattr_1 {{'exclude_from_explicit_instantiation' attribute takes precedence over 'dllexport' attribute on the enclosing class}}
+// expected-note@#dllattr_1 {{attribute is here}}
+// expected-warning@#excludeattr_2 {{'exclude_from_explicit_instantiation' attribute takes precedence over 'dllimport' attribute on the enclosing class}}
+// expected-note@#dllattr_2 {{attribute is here}}
