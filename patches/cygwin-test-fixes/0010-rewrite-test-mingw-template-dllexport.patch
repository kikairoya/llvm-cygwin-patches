+  static int StaticVar;
+  static inline int InlineVar = 0;
+  struct Nested {
+    Nested(const Nested &) {}
+    Nested(Nested &&) {}
+    static void Method();
+    static void Inlined() {}
+    static int StaticVar;
+    static inline int InlineVar = 0;
+    struct DeepNested {
+      DeepNested(const DeepNested &) {}
+      DeepNested(DeepNested &&) {}
+      static void Method();
+      static void Inlined() {}
+      static int StaticVar;
+      static inline int InlineVar = 0;
+    };
+    static void Specialized() {}
+  };
+  static void Specialized() {}
+};
