 // diff the result against the original.
 
 // REQUIRES: plugins
+// UNSUPPORTED: system-windows
+// UNSUPPORTED: system-cygwin
 
 // RUN: rm -rf %t
 // RUN: mkdir -p %t
diff --git a/clang/test/Analysis/Scalable/ssaf-format/TUSummary/summary-data.test b/clang/test/Analysis/Scalable/ssaf-format/TUSummary/summary-data.test
