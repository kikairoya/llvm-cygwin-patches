From b4ff8c1080ae40c5391463fc6709006f7fdc57d0 Mon Sep 17 00:00:00 2001
From: kikairoya <kikairoya@gmail.com>
Date: Fri, 13 Mar 2026 21:07:39 +0900
Subject: [PATCH 15/45] 1

---
 clang/lib/Sema/SemaDeclCXX.cpp                |  12 +-
 clang/lib/Sema/SemaTemplateInstantiate.cpp    |   7 +-
 .../CodeGenCXX/mingw-template-dllexport-2.cpp | 195 ++++++++++++++++++
 3 files changed, 208 insertions(+), 6 deletions(-)
 create mode 100644 clang/test/CodeGenCXX/mingw-template-dllexport-2.cpp

diff --git a/clang/lib/Sema/SemaDeclCXX.cpp b/clang/lib/Sema/SemaDeclCXX.cpp
index 8538df4298b22af7e30c63d6fa775c234d47bbea..d42b2dc92751d04fa9204beadc3321dceae82a8b 100644
--- a/clang/lib/Sema/SemaDeclCXX.cpp
+++ b/clang/lib/Sema/SemaDeclCXX.cpp
@@ -6612,13 +6612,17 @@ void Sema::checkClassLevelDLLAttribute(CXXRecordDecl *Class) {
       continue;
 
     // Inherit dllexport to nested class in MinGW mode.
-    if (TI.getTriple().isOSCygMing() && !getDLLAttr(Member) &&
-        (TSK == TSK_ExplicitInstantiationDeclaration ||
-         TSK == TSK_ExplicitInstantiationDefinition) &&
-        isa<RecordDecl>(Member)) {
+    if (auto *RD = dyn_cast<CXXRecordDecl>(Member);
+        RD && TI.getTriple().isOSCygMing() && !getDLLAttr(Member) &&
+        isTemplateInstantiation(RD->getTemplateSpecializationKind())) {
+
       auto *NewAttr = cast<InheritableAttr>(ClassAttr->clone(getASTContext()));
       NewAttr->setInherited(true);
       Member->addAttr(NewAttr);
+
+      if (RD->getDefinition())
+        checkClassLevelDLLAttribute(RD);
+
       continue;
     }
 
diff --git a/clang/lib/Sema/SemaTemplateInstantiate.cpp b/clang/lib/Sema/SemaTemplateInstantiate.cpp
index ebdeecd8f112c774d73df7ed1a5a3b603ba8eccf..6f051ca17464ba01558ec7f1fb765301c532394d 100644
--- a/clang/lib/Sema/SemaTemplateInstantiate.cpp
+++ b/clang/lib/Sema/SemaTemplateInstantiate.cpp
@@ -4269,11 +4269,14 @@ Sema::InstantiateClassMembers(SourceLocation PointOfInstantiation,
                          TemplateArgs,
                          TSK);
       } else {
+        auto MemberTSK = Record->getTemplateSpecializationKind();
         if (TSK == TSK_ExplicitInstantiationDefinition &&
-            Record->getTemplateSpecializationKind() ==
-                TSK_ExplicitInstantiationDeclaration) {
+            MemberTSK == TSK_ExplicitInstantiationDeclaration) {
           Record->setTemplateSpecializationKind(TSK);
           MarkVTableUsed(PointOfInstantiation, Record, true);
+        } else if (TSK == TSK_ExplicitInstantiationDeclaration &&
+                   MemberTSK == TSK_ImplicitInstantiation) {
+          Record->setTemplateSpecializationKind(TSK);
         }
       }
 
diff --git a/clang/test/CodeGenCXX/mingw-template-dllexport-2.cpp b/clang/test/CodeGenCXX/mingw-template-dllexport-2.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..100eba89a5657be5407704fb7b199f9958212ea2
--- /dev/null
+++ b/clang/test/CodeGenCXX/mingw-template-dllexport-2.cpp
@@ -0,0 +1,195 @@
+// RUN: %clang_cc1 -emit-llvm -triple x86_64-mingw %s -o - | FileCheck %s
+// RUN: %clang_cc1 -emit-llvm -triple x86_64-mingw %s -o - | FileCheck %s --check-prefixes=VAR
+// RUN: %clang_cc1 -emit-llvm -triple x86_64-cygwin %s -o - | FileCheck %s
+
+// Check that an explicit template instantiation declaration with dllexport makes
+// nested class be exported also.
+
+#define CAT1(a,b) a##b
+#define CAT(a,b) CAT1(a,b)
+#define USE(m) __attribute__((used)) auto CAT(anchor_,__LINE__) = m
+
+struct ExportDefinition;
+struct ExportDeclaration;
+struct NonExportDeclaration;
+struct SpecializeOuterMethod;
+struct SpecializeOuterMethodNonExportDeclaration;
+struct SpecializeNestedMethod;
+struct SpecializeBothMethods;
+struct SpecializeNestedClass;
+struct SpecializeWholeClass;
+
+template <typename T>
+struct Class {
+  Class(const Class &) {}
+  Class(Class &&) noexcept {}
+  static void Specialized() {}
+  static void Method();
+  static void Inlined() {}
+  static int Var;
+  static inline int InlineVar = 0;
+  struct Nested {
+    static void Specialized() {}
+    static void Method();
+    static void Inlined() {}
+    static int Var;
+    static inline int InlineVar = 0;
+    struct DeepNested {
+      static void Method();
+      static void Inlined() {}
+      static int Var;
+      static inline int InlineVar = 0;
+    };
+  };
+};
+template <typename T>
+void Class<T>::Method() {}
+template <typename T>
+void Class<T>::Nested::Method() {}
+template <typename T>
+void Class<T>::Nested::DeepNested::Method() {}
+template <typename T>
+int Class<T>::Var = 0;
+template <typename T>
+int Class<T>::Nested::Var = 0;
+template <typename T>
+int Class<T>::Nested::DeepNested::Var = 0;
+
+// Check that a dllexport-ed explicit instantiation definition makes all members dllexport-ed.
+template struct __declspec(dllexport) Class<ExportDefinition>;
+// VAR: @_ZN5ClassI16ExportDefinitionE3VarE = weak_odr dso_local dllexport global
+// VAR: @_ZN5ClassI16ExportDefinitionE9InlineVarE = weak_odr dso_local dllexport global
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionEC1ERKS1_
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionEC1EOS1_
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionE11SpecializedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionE6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionE7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionE6Nested11SpecializedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionE6Nested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionE6Nested7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionE6Nested10DeepNested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI16ExportDefinitionE6Nested10DeepNested7InlinedEv
+
+// Check that a dllexport-ed explicit instantiation declaration makes all members dllexport-ed.
+extern template struct __declspec(dllexport) Class<ExportDeclaration>;
+template struct Class<ExportDeclaration>;
+// VAR: @_ZN5ClassI17ExportDeclarationE3VarE = weak_odr dso_local dllexport global
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI17ExportDeclarationE11SpecializedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI17ExportDeclarationE6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI17ExportDeclarationE7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI17ExportDeclarationE6Nested11SpecializedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI17ExportDeclarationE6Nested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI17ExportDeclarationE6Nested7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI17ExportDeclarationE6Nested10DeepNested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI17ExportDeclarationE6Nested10DeepNested7InlinedEv
+
+// Check that a dllexport-ed instantiation which has declared already without dllexport doesn't make members dllexport-ed.
+extern template struct Class<NonExportDeclaration>;
+template struct __declspec(dllexport) Class<NonExportDeclaration>;
+// VAR: @_ZN5ClassI20NonExportDeclarationE3VarE = weak_odr dso_local global
+// CHECK: define weak_odr dso_local void @_ZN5ClassI20NonExportDeclarationE6MethodEv
+// CHECK: define weak_odr dso_local void @_ZN5ClassI20NonExportDeclarationE6Nested6MethodEv
+
+// Check that a specialized member doesn't prevent other members to be dllexport-ed.
+template <> void Class<SpecializeOuterMethod>::Specialized() {}
+// CHECK: define dso_local void @_ZN5ClassI21SpecializeOuterMethodE11SpecializedEv
+extern template struct __declspec(dllexport) Class<SpecializeOuterMethod>;
+template struct Class<SpecializeOuterMethod>;
+// VAR: @_ZN5ClassI21SpecializeOuterMethodE3VarE = weak_odr dso_local dllexport global
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeOuterMethodE6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeOuterMethodE7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeOuterMethodE6Nested11SpecializedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeOuterMethodE6Nested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeOuterMethodE6Nested7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeOuterMethodE6Nested10DeepNested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeOuterMethodE6Nested10DeepNested7InlinedEv
+
+// Check that a dllexport-ed instantiation which has a specialized member doesn't make members dllexport-ed.
+template <> __declspec(dllexport) void Class<SpecializeOuterMethodNonExportDeclaration>::Specialized() {}
+// CHECK: define dso_local dllexport void @_ZN5ClassI41SpecializeOuterMethodNonExportDeclarationE11SpecializedEv
+
+template struct __declspec(dllexport) Class<SpecializeOuterMethodNonExportDeclaration>;
+// VAR: @_ZN5ClassI41SpecializeOuterMethodNonExportDeclarationE3VarE = weak_odr dso_local global
+// CHECK: define weak_odr dso_local void @_ZN5ClassI41SpecializeOuterMethodNonExportDeclarationE6MethodEv
+// CHECK: define weak_odr dso_local void @_ZN5ClassI41SpecializeOuterMethodNonExportDeclarationE6Nested6MethodEv
+
+// Check that a specialized member of nested class doesn't prevent other members to be dllexport-ed.
+template <> void Class<SpecializeNestedMethod>::Nested::Specialized() {}
+// CHECK: define dso_local void @_ZN5ClassI22SpecializeNestedMethodE6Nested11SpecializedEv
+
+extern template struct __declspec(dllexport) Class<SpecializeNestedMethod>;
+template struct Class<SpecializeNestedMethod>;
+// VAR: @_ZN5ClassI22SpecializeNestedMethodE3VarE = weak_odr dso_local dllexport global
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI22SpecializeNestedMethodE11SpecializedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI22SpecializeNestedMethodE6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI22SpecializeNestedMethodE7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI22SpecializeNestedMethodE6Nested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI22SpecializeNestedMethodE6Nested7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI22SpecializeNestedMethodE6Nested10DeepNested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI22SpecializeNestedMethodE6Nested10DeepNested7InlinedEv
+
+template <> void Class<SpecializeBothMethods>::Specialized() {}
+// CHECK: define dso_local void @_ZN5ClassI21SpecializeBothMethodsE11SpecializedEv
+
+template <> void Class<SpecializeBothMethods>::Nested::Specialized() {}
+// CHECK: define dso_local void @_ZN5ClassI21SpecializeBothMethodsE6Nested11SpecializedEv
+
+extern template struct __declspec(dllexport) Class<SpecializeBothMethods>;
+template struct Class<SpecializeBothMethods>;
+// VAR: @_ZN5ClassI21SpecializeBothMethodsE3VarE = weak_odr dso_local dllexport global
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeBothMethodsE6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeBothMethodsE7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeBothMethodsE6Nested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeBothMethodsE6Nested7InlinedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeBothMethodsE6Nested10DeepNested6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeBothMethodsE6Nested10DeepNested7InlinedEv
+
+// Check that a specialized nested class doesn't prevent other members to be dllexport-ed.
+template <>
+struct __declspec(dllexport) Class<SpecializeNestedClass>::Nested {
+  static void Method();
+  static void Inlined() {}
+  static inline int Var{};
+};
+// VAR: @_ZN5ClassI21SpecializeNestedClassE3VarE = weak_odr dso_local dllexport global
+
+void Class<SpecializeNestedClass>::Nested::Method() {}
+// CHECK: define dso_local dllexport void @_ZN5ClassI21SpecializeNestedClassE6Nested6MethodEv
+
+extern template struct __declspec(dllexport) Class<SpecializeNestedClass>;
+template struct Class<SpecializeNestedClass>;
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeNestedClassE11SpecializedEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeNestedClassE6MethodEv
+// CHECK: define weak_odr dso_local dllexport void @_ZN5ClassI21SpecializeNestedClassE7InlinedEv
+
+// A fully-specialized nested class isn't treated as a template, so an inline method won't be exported.
+USE(&Class<SpecializeNestedClass>::Nested::Inlined);
+// CHECK: define linkonce_odr dso_local void @_ZN5ClassI21SpecializeNestedClassE6Nested7InlinedEv
+
+// Check that a fully-specialized class doesn't export its non-exported nested class.
+template <>
+struct __declspec(dllexport) Class<SpecializeWholeClass> {
+  static void Method();
+  static void Inlined() {}
+  static inline int Var{};
+  struct Nested {
+    static void Method();
+  };
+  struct __declspec(dllexport)  ExportedNested {
+    static void Method();
+  };
+};
+// VAR: @_ZN5ClassI20SpecializeWholeClassE3VarE = weak_odr dso_local dllexport global
+
+void Class<SpecializeWholeClass>::Method() {}
+// CHECK: define dso_local dllexport void @_ZN5ClassI20SpecializeWholeClassE6MethodEv
+
+// A fully-specialized class isn't treated as a template, so an inline method won't be exported.
+USE(&Class<SpecializeWholeClass>::Inlined);
+// CHECK: define linkonce_odr dso_local void @_ZN5ClassI20SpecializeWholeClassE7InlinedEv
+
+void Class<SpecializeWholeClass>::Nested::Method() {}
+// CHECK: define dso_local void @_ZN5ClassI20SpecializeWholeClassE6Nested6MethodEv
+
+void Class<SpecializeWholeClass>::ExportedNested::Method() {}
+// CHECK: define dso_local dllexport void @_ZN5ClassI20SpecializeWholeClassE14ExportedNested6MethodEv
-- 
2.53.0

